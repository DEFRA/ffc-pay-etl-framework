{
  "name": "ffc-pay-etl-framework",
  "version": "1.4.1",
  "publisher": "Defra",
  "main": "src/index.js",
  "private": false,
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watchAll",
    "test:lint": "eslint",
    "test:lint:fix": "eslint --fix",
    "dev": "nodemon src/index.js",
    "clean": "rm -rf ./dist",
    "example": "node ./src/examples/sql-return-values.js"
  },
  "keywords": [
    "ETL"
  ],
  "author": "Defra",
  "contributors": [
    "Charlie Benger-Stevenson charlie.benger-stevenson.external@eviden.com",
    "Leigh Godson leigh.godson@atos.net",
    "Sam Plackett samuel.plackett@atos.net"
  ],
  "license": "OGL-UK-3.0",
  "repository": "https://github.com/DEFRA/ffc-pay-etl-framework",
  "description": "A framework for creating ETL pipelines in node",
  "jest": {
    "setupFiles": [
      "<rootDir>/jest/setEnvVars.js"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "**/*.js",
      "!**/*.test.js"
    ],
    "coverageDirectory": "test-output",
    "coverageReporters": [
      "text-summary",
      "lcov"
    ],
    "coveragePathIgnorePatterns": [
      "<rootDir>/node_modules/",
      "<rootDir>/test-output/",
      "<rootDir>/test/"
    ],
    "modulePathIgnorePatterns": [
      "node_modules"
    ],
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "suiteName": "jest tests",
          "outputDirectory": "test-output",
          "outputName": "junit.xml"
        }
      ]
    ]
  },
  "devDependencies": {
    "debug": "4.3.6",
    "eslint": "9.39.1",
    "jest": "29.7.0",
    "jest-junit": "16.0.0",
    "neostandard": "0.12.2",
    "nodemon": "3.1.4",
    "prettier": "3.3.3"
  },
  "dependencies": {
    "@faker-js/faker": "8.4.1",
    "csv-parse": "6.1.0",
    "sequelize": "6.37.3",
    "validator": "13.15.23"
  },
  "files": [
    "/dist/**/*"
  ],
  "exports": {
    ".": {
      "import": {
        "default": "./dist/esm/index.js"
      },
      "require": {
        "default": "./dist/cjs/index.js"
      }
    }
  }
}
